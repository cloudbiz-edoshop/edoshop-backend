{
  "name": "edoshop-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "minio:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-minio.ps1",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "cross-env DB_MIGRATING=true tsx src/db/migrate.ts",
    "db:seed": "cross-env DB_SEEDING=true tsx src/db/seed.ts",
    "db:reset-sequences": "tsx src/db/run-reset-sequences.ts",
    "db:drop": "tsx src/db/drop.ts",
    "db:studio": "drizzle-kit studio",
    "users:upsert-team": "tsx src/scripts/upsert-team-admin-users.ts",
    "rayons:repair-bins": "tsx src/scripts/repair-rayon-bin-layouts.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@hono/node-server": "^2.0.2",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.14",
    "argon2": "^0.44.0",
    "bwip-js": "^4.10.1",
    "country-state-city": "^3.2.1",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.18",
    "hono-pino": "^0.10.3",
    "minio": "^8.0.7",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "tsx": "^4.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
